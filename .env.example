# ─────────────────────────────────────────────────────────────────
# Atolls MCP Server – Environment Variables
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────

# Base URL of your Atolls REST API (no trailing slash)
ATOLLS_API_BASE_URL=https://api.atolls.com/v1

# API key for authenticating requests to your backend
ATOLLS_API_KEY=your_api_key_here

# Optional: default currency for cashback display (ISO 4217)
ATOLLS_DEFAULT_CURRENCY=GBP

# Optional: max results returned by the search tool (default 10)
ATOLLS_SEARCH_LIMIT=10

# Optional: port if you switch to HTTP transport instead of stdio
PORT=3000
